# ZARA Interpreter - Environment Configuration
# Copy this file to .env and adjust values as needed

# Server Port (Render will override this with its own PORT)
PORT=8080

# Java Memory Settings (for Render free tier)
JAVA_OPTS=-Xmx300m -Xms75m

# Logging Level
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_ZARA_INTERPRETER=INFO

# Application Limits
ZARA_MAX_EXECUTION_TIME_MS=30000
ZARA_MAX_OUTPUT_LINES=10000

# Spring Profile
SPRING_PROFILES_ACTIVE=production
